# MongoDB (local o Atlas)
# Local:
#   MONGO_URL=mongodb://localhost:27017
# Atlas: usa tu SRV connection string (reemplaza <password> si lo guardas aparte)
#   MONGO_URL=mongodb+srv://<user>:<password>@maqgo-cluster.xxxxx.mongodb.net/maqgo_db?appName=maqgo-cluster
MONGO_URL=mongodb://localhost:27017
DB_NAME=maqgo_db

# ========== OTP (códigos de verificación) ==========
# OTP propio: Redis + LabsMobile (sin proveedores Verify externos).
# En Railway: estas variables van en el MISMO servicio que corre el API (no en el frontend).
# Verificación prod: GET /healthz/otp-readiness → ready: true
REDIS_URL=
LABSMOBILE_USERNAME=
LABSMOBILE_API_TOKEN=
LABSMOBILE_SENDER=MAQGO
# Alerta admin cuando el saldo baja de este umbral (créditos LabsMobile)
SMS_LOW_BALANCE_THRESHOLD=300

# Twilio se mantiene para WhatsApp/notificaciones no OTP (si usas esos flujos).
MAQGO_DEMO_MODE=true
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# URL pública donde entra el usuario (OneClick return, emails, links). En prod: https://www.maqgo.cl
# El API puede ser otro host (ej. api2.maqgo.cl); CORS debe listar el origen del front.
FRONTEND_URL=http://localhost:5173

# ========== Transbank OneClick Mall ==========
# Docs: https://www.transbankdevelopers.cl/referencia/oneclick
# Tarjetas de prueba: https://www.transbankdevelopers.cl/documentacion/como_empezar#ambientes

# Ambiente: integration | production
TBK_ENV=integration

# Código comercio padre (Mall) y tienda hija
# Integración: 597055555541 (padre), 597055555542 (hija)
TBK_PARENT_COMMERCE_CODE=597055555541
TBK_CHILD_COMMERCE_CODE=597055555542

# Llave secreta (integración: la del SDK de ejemplo).
# Compatibilidad: también puedes usar TBK_API_KEY (alias).
TBK_API_KEY_SECRET=579B532A7440BB0C9079DED94D31EA1615BACEB56610332264630D42D0A36B1C
TBK_API_KEY=
# Opcional: si Transbank te entrega API Key ID explícito distinto del commerce code.
# Si no se define, se usa TBK_PARENT_COMMERCE_CODE.
TBK_API_KEY_ID=

# URL de retorno para Transbank (IMPORTANTE)
# Transbank redirige aquí tras la inscripción. Debe ser accesible desde internet.
# Con localhost NO funciona: Transbank no puede alcanzar tu máquina.
# Para pruebas locales: usa ngrok y pon aquí la URL pública, ej:
#   TBK_RETURN_URL=https://abc123.ngrok.io/api/payments/oneclick/confirm-return
# Si API y front van en el mismo host (Railway Dockerfile raíz): ej.
#   TBK_RETURN_URL=https://www.maqgo.cl/api/payments/oneclick/confirm-return
TBK_RETURN_URL=

# Transbank: true = no cobra real, false = cobro real (producción)
TBK_DEMO_MODE=true
# Reintentos transitorios en llamadas HTTP a Transbank (5xx/408/429).
TBK_REQUEST_RETRIES=2

# Guardas para endpoints públicos de validación Oneclick (start/authorize/test-flow).
# En producción real dejar false. Para validación externa en integration:
# - ONECLICK_PUBLIC_VALIDATION_ENABLED=true
# - y usar token o IP allowlist.
ONECLICK_PUBLIC_VALIDATION_ENABLED=false
ONECLICK_VALIDATION_TOKEN=
ONECLICK_VALIDATION_IP_ALLOWLIST=

# Google Maps (backend /api/maps - autocomplete, place-details, ETA)
# El frontend usa VITE_GOOGLE_MAPS_API_KEY para Places directo
GOOGLE_MAPS_API_KEY=

# Resend (emails): facturas y notificaciones (opcional)
RESEND_API_KEY=
SENDER_EMAIL=onboarding@resend.dev

# SMTP transaccional (opcional, prioridad sobre Resend).
# Sirve para proveedores externos con plan gratis (ej: Bravo si entrega SMTP).
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
EMAIL_SMTP_SSL=false

# Twilio WhatsApp (opcional)
TWILIO_WHATSAPP_FROM=

# ========== PRODUCCIÓN ==========
# MAQGO_ENV=production activa avisos críticos si DEMO_MODE está activo (OTP 123456 para cualquier número)
MAQGO_ENV=development

# Orígenes del front (scheme+host, sin path). Separados por comas. NO uses * en producción con credenciales.
# Incluye localhost si pruebas Vite contra este API:
CORS_ORIGINS=http://localhost:5173,https://www.maqgo.cl,https://maqgo.cl
