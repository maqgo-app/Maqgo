# Obligatorio para que arranque el front (api.js lanza si falta).
# Local: apunta a tu API FastAPI. Producción (Vercel): https://api.maqgo.cl
REACT_APP_BACKEND_URL=http://localhost:8002

# Modo live / producción en el cliente (npm run dev contra API real). Opcional.
# Sin esto, Vite en desarrollo trata el build como no-prod (demo UI, etc.).
# Valores recomendados si pruebas contra api*.maqgo.cl:
# VITE_IS_PRODUCTION=true
# VITE_MAQGO_ENV=production
# VITE_ENABLE_DEMO_MODE=false

# Opcional: Para autocompletado de direcciones exactas (Google Places API)
# Obtén tu API key en: https://console.cloud.google.com/
# Habilita: Maps JavaScript API y Places API
# Restringe la key a tu dominio en producción
VITE_GOOGLE_MAPS_API_KEY=
