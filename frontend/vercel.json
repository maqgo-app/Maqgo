{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "maqgo.cl" }],
      "destination": "https://www.maqgo.cl/:path*",
      "statusCode": 301
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
