{
  "redirects": [
    {
      "source": "/select-channel",
      "destination": "/login",
      "permanent": false
    },
    {
      "source": "/provider/select-channel",
      "destination": "/provider/register",
      "permanent": false
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "maqgo.cl" }],
      "destination": "https://www.maqgo.cl/:path*",
      "statusCode": 301
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://api2.maqgo.cl/api/:path*"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
