# Copiar a .env.production y rellenar antes de: npm run build
# Sin barra final.
#
# Split (usuarios en www, API en otro host — lo habitual con api.maqgo.cl en Railway):
REACT_APP_BACKEND_URL=https://api.maqgo.cl
#
# Unificado (mismo host www + /api — Dockerfile raíz en Railway):
# REACT_APP_BACKEND_URL=https://www.maqgo.cl
#
# Ver docs/MODELOS_DEPLOY.md

# Opcional: Google Maps (autocompletado de direcciones)
VITE_GOOGLE_MAPS_API_KEY=

# Opcional: WhatsApp soporte (botón flotante)
VITE_WHATSAPP_SUPPORT=+56994336579
