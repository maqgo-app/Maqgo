# Copiar a .env.production y rellenar antes de: npm run build
# La URL debe ser la de tu API en producción (sin barra final)

# Frontend público (Vercel) — referencia para enlaces / integraciones
# VITE_PUBLIC_SITE_URL=https://maqgo.vercel.app

REACT_APP_BACKEND_URL=https://api.maqgo.cl
# Alternativa si usas Vite env:
# VITE_BACKEND_URL=https://api.maqgo.cl

# Opcional: Google Maps (autocompletado de direcciones)
VITE_GOOGLE_MAPS_API_KEY=

# Opcional: WhatsApp soporte (botón flotante)
VITE_WHATSAPP_SUPPORT=+56994336579
