# Copiar a .env.production y rellenar antes de: npm run build
# Obligatorio. Sin barra final. Sin esto el bundle lanza "BACKEND URL NOT CONFIGURED" al cargar.
# Vercel: REACT_APP_BACKEND_URL=https://api2.maqgo.cl (API directo; sin rewrite /api en Vercel).
# Alternativa si el API público es otro host:
# REACT_APP_BACKEND_URL=https://api.maqgo.cl

# Producción (obligatorio en Vercel / build release — sin demo en cliente)
VITE_IS_PRODUCTION=true
VITE_MAQGO_ENV=production
VITE_ENABLE_DEMO_MODE=false

# Opcional: Google Maps (autocompletado de direcciones)
VITE_GOOGLE_MAPS_API_KEY=

# Opcional: WhatsApp soporte (botón flotante)
VITE_WHATSAPP_SUPPORT=+56994336579
