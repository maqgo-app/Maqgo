{
  "name": "maqgo-frontend",
  "private": true,
  "version": "0.0.1",
  "engines": {
    "node": ">=20.0.0"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "build": "vite build",
    "verify:build": "npm run build && node scripts/verify-build.mjs",
    "generate:pwa-assets": "node scripts/generate-pwa-assets.mjs",
    "test:guardrails": "VITE_IS_PRODUCTION=true VITE_MAQGO_ENV=production VITE_ENABLE_DEMO_MODE=false vitest run src/guardrails/productionNoDemoUi.test.jsx --mode production",
    "gate:deploy": "npm run test:unit && npm run test:guardrails && npm run verify:build",
    "lint": "eslint .",
    "preview": "vite preview",
    "preview:e2e": "vite preview",
    "test": "npm run test:unit",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test qa-artifacts",
    "test:e2e:preview": "npm run build && npm run preview:e2e",
    "test:e2e:checkout": "playwright test qa-artifacts/checkout-navigation.spec.js",
    "test:e2e:sellado": "playwright test qa-artifacts/smoke-sellado.spec.js",
    "test:e2e:critical": "playwright test qa-artifacts/smoke-critical-paths.spec.js"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/space-grotesk": "^5.2.10",
    "axios": "^1.13.5",
    "jspdf": "^4.2.1",
    "leaflet": "^1.9.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^6.30.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.0"
  },
  "optionalDependencies": {
    "sharp": "^0.33.5",
    "to-ico": "^1.1.5"
  }
}
